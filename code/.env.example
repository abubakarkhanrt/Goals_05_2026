# LLM backend is chosen at startup via ADK entry point (recommended):
#   adk run code_local   → local Ollama
#   adk run code_cloud   → cloud Gemini (requires GOOGLE_API_KEY)
# Or set TRANSCRIPT_LLM_BACKEND=local|cloud manually.

# Cloud Gemini (used by adk run code_cloud)
# GOOGLE_API_KEY="YOUR_GOOGLE_API_KEY"
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# CLOUD_MODEL=gemini/gemini-2.0-flash

# Local Ollama (used by adk run code_local)
USE_OLLAMA=true
OLLAMA_MODEL=ollama/gemma4:26b
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_TEMPERATURE=0.2

# Set USE_OLLAMA=false for rule-based scoring only (no LLM).

# Session PDF image cache (PNG renders for vision LLMs)
SESSION_CACHE_DIR=.session_cache
PDF_RENDER_DPI=150
PDF_MAX_PAGES=20

# Optional: Google Gemini (not used by default — assessment uses local Ollama or rules).
GOOGLE_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxx"
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# LLM vision latency tuning (local and cloud)
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_IMAGE_MAX_EDGE=1024
OLLAMA_MAX_IMAGES=4
# OLLAMA_SEND_IMAGES=false

# Prometheus metrics (see monitoring/README.md)
# AGENT_METRICS_ENABLED=true
# AGENT_METRICS_PORT=9464

# SQLite persistence (verification history + messages + tool/LLM audit)
AGENT_DB_ENABLED=true
AGENT_DB_PATH=.data/transcript_agent.db
