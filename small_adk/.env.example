# Cloud Gemini (used when internet is on AND GOOGLE_API_KEY is set)
GOOGLE_API_KEY=
# FALSE = Google AI Studio (API key). TRUE = Vertex AI (OAuth / service account, not API key).
GOOGLE_GENAI_USE_VERTEXAI=FALSE
# Native ADK name (recommended). gemini/... LiteLLM form is also accepted.
CLOUD_MODEL=gemini-2.0-flash

# Local Ollama (used when offline, or when online without an API key)
OLLAMA_MODEL=ollama/gemma4:26b
OLLAMA_API_BASE=http://localhost:11434
LLM_TEMPERATURE=0.3

# Workshop / performance toggles
# WORKSHOP_MODE=local          # force Ollama + offline riddles (stable demos)
# SKIP_STARTUP_PROBE=true      # skip 3s Google probe at import; probe on first riddle
# CONNECTIVITY_CACHE_TTL=60    # seconds to reuse check_internet result in session

# Optional overrides
# RIDDLES_API_URL=https://riddles-api.vercel.app/random
# INTERNET_PROBE_URL=https://www.google.com
